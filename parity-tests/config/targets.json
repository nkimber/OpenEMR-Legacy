{
  "targets": [
    {
      "id": "legacy-openemr",
      "name": "Legacy OpenEMR",
      "status": "implemented",
      "type": "legacy-openemr",
      "appId": "legacy-openemr",
      "publicUrl": "http://localhost:8080",
      "healthUrl": "https://localhost:9443/meta/health/readyz",
      "workingDirectory": "../legacy-openemr",
      "envPath": "../legacy-openemr/.env",
      "sourcePath": "../legacy-openemr/source",
      "seedDatasetId": "openemr-shared-synthetic-v1",
      "seedSummaryPath": "../modernization-workbench/seed-data/openemr-shared-synthetic-v1/generated/summary.json",
      "defaultCredentials": {
        "username": "admin",
        "password": "pass"
      },
      "database": {
        "kind": "mariadb",
        "composeService": "mysql",
        "defaultDatabase": "openemr",
        "defaultUser": "openemr"
      },
      "commands": {
        "start": ["docker", "compose", "up", "-d"],
        "status": ["docker", "compose", "ps", "--format", "json"],
        "reset": ["powershell", "-ExecutionPolicy", "Bypass", "-File", ".\\scripts\\Seed-LegacyGoldDataset.ps1"],
        "smoke": ["powershell", "-ExecutionPolicy", "Bypass", "-File", ".\\scripts\\Test-LegacyBaseline.ps1"]
      }
    },
    {
      "id": "modernized-openemr",
      "name": "Modernized OpenEMR",
      "status": "implemented",
      "type": "modernized-openemr",
      "appId": "modernized-openemr",
      "publicUrl": "http://localhost:3000",
      "apiBaseUrl": "http://localhost:5001",
      "healthUrl": "http://localhost:5001/health",
      "workingDirectory": "../modernized-openemr",
      "envPath": "../modernized-openemr/.env",
      "seedDatasetId": "openemr-shared-synthetic-v1",
      "seedSummaryPath": "../modernization-workbench/seed-data/openemr-shared-synthetic-v1/generated/summary.json",
      "defaultCredentials": {
        "username": "admin",
        "password": "pass"
      },
      "database": {
        "kind": "postgres",
        "composeService": "postgres",
        "defaultDatabase": "openemr_modernized",
        "defaultUser": "openemr"
      },
      "commands": {
        "start": ["docker", "compose", "up", "-d"],
        "status": ["docker", "compose", "ps", "--format", "json"],
        "reset": ["powershell", "-ExecutionPolicy", "Bypass", "-File", ".\\scripts\\Seed-ModernizedGoldDataset.ps1"],
        "smoke": ["powershell", "-ExecutionPolicy", "Bypass", "-File", ".\\scripts\\Test-ModernizedBaseline.ps1"]
      }
    }
  ]
}
