{
  "name": "openemr-parity-tests",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "tsx src/cli/run-tests.ts --target legacy-openemr --suite all",
    "test:legacy": "tsx src/cli/run-tests.ts --target legacy-openemr --suite all",
    "test:legacy:database": "tsx src/cli/run-tests.ts --target legacy-openemr --suite database",
    "test:legacy:http": "tsx src/cli/run-tests.ts --target legacy-openemr --suite http",
    "test:legacy:ui": "tsx src/cli/run-tests.ts --target legacy-openemr --suite ui",
    "test:legacy:ui:headed": "tsx src/cli/run-tests.ts --target legacy-openemr --suite ui --headed",
    "test:legacy:workflow": "tsx src/cli/run-tests.ts --target legacy-openemr --suite workflow",
    "test:legacy:plan:readiness": "tsx src/cli/run-tests.ts --target legacy-openemr --plan legacy-readiness",
    "test:legacy:plan:mutation": "tsx src/cli/run-tests.ts --target legacy-openemr --plan mutation-isolated",
    "test:legacy:plan:full": "tsx src/cli/run-tests.ts --target legacy-openemr --plan full-parity",
    "test:modernized": "tsx src/cli/run-tests.ts --target modernized-openemr --plan slice-1-readiness",
    "test:modernized:database": "tsx src/cli/run-tests.ts --target modernized-openemr --suite database",
    "test:modernized:http": "tsx src/cli/run-tests.ts --target modernized-openemr --suite http",
    "test:modernized:ui": "tsx src/cli/run-tests.ts --target modernized-openemr --suite ui",
    "test:modernized:plan:slice1": "tsx src/cli/run-tests.ts --target modernized-openemr --plan slice-1-readiness",
    "test:modernized:plan:scheduling": "tsx src/cli/run-tests.ts --target modernized-openemr --plan slice-2-scheduling-readiness",
    "test:legacy:plan:scheduling": "tsx src/cli/run-tests.ts --target legacy-openemr --plan slice-2-scheduling-readiness",
    "list": "tsx src/cli/run-tests.ts --list",
    "compare": "tsx src/cli/compare-runs.ts",
    "typecheck": "tsc --noEmit",
    "playwright": "playwright"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
