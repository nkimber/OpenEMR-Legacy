{
  "name": "modernization-workbench",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,ui -c green,cyan \"npm:dev:api\" \"npm:dev:ui\"",
    "dev:api": "tsx watch server/index.ts",
    "dev:ui": "vite --host 127.0.0.1 --port 5173",
    "generate:seed-data": "node seed-data/openemr-shared-synthetic-v1/scripts/generate-gold-dataset.mjs",
    "build": "tsc && vite build",
    "start": "npm run dev",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "vite": "^7.3.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  }
}
