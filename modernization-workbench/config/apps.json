{
  "apps": [
    {
      "id": "legacy-openemr",
      "name": "Legacy OpenEMR",
      "stage": "Baseline reference",
      "description": "Pinned original OpenEMR application running through Docker Compose.",
      "kind": "docker-compose",
      "workingDirectory": "../legacy-openemr",
      "publicUrl": "http://localhost:8080",
      "healthUrl": "https://localhost:9443/meta/health/readyz",
      "documentationPath": "../documents/LEGACY_OPENEMR_BASELINE.md",
      "sourcePath": "../legacy-openemr/source",
      "expectedSourceTag": "v8_1_0",
      "commands": {
        "status": ["docker", "compose", "ps", "--format", "json"],
        "start": ["docker", "compose", "up", "-d"],
        "stop": ["docker", "compose", "down"],
        "restart": ["docker", "compose", "restart"],
        "logs": ["docker", "compose", "logs", "--tail", "160"],
        "seedGoldDataset": ["powershell", "-ExecutionPolicy", "Bypass", "-File", ".\\scripts\\Seed-LegacyGoldDataset.ps1"],
        "seedExampleData": ["powershell", "-ExecutionPolicy", "Bypass", "-File", ".\\scripts\\Seed-LegacyExampleData.ps1"],
        "smokeTest": ["powershell", "-ExecutionPolicy", "Bypass", "-File", ".\\scripts\\Test-LegacyBaseline.ps1"],
        "parityDatabaseTests": ["powershell", "-ExecutionPolicy", "Bypass", "-File", "..\\scripts\\Run-OpenEmrParityTests.ps1", "-Target", "legacy-openemr", "-Suite", "database", "-Reset", "run"],
        "parityHttpTests": ["powershell", "-ExecutionPolicy", "Bypass", "-File", "..\\scripts\\Run-OpenEmrParityTests.ps1", "-Target", "legacy-openemr", "-Suite", "http", "-Reset", "none"],
        "parityUiTests": ["powershell", "-ExecutionPolicy", "Bypass", "-File", "..\\scripts\\Run-OpenEmrParityTests.ps1", "-Target", "legacy-openemr", "-Suite", "ui", "-Reset", "run"],
        "parityAllTests": ["powershell", "-ExecutionPolicy", "Bypass", "-File", "..\\scripts\\Run-OpenEmrParityTests.ps1", "-Target", "legacy-openemr", "-Suite", "all", "-Reset", "run"]
      },
      "services": ["mysql", "openemr"],
      "seeds": [
        {
          "id": "gold-test-dataset-v1",
          "datasetId": "openemr-shared-synthetic-v1",
          "name": "Gold test dataset v1",
          "description": "Resets the legacy data tables and applies the 1,000-patient shared synthetic gold dataset.",
          "commandName": "seedGoldDataset",
          "resultPath": "../legacy-openemr/artifacts/latest-gold-seed-result.json"
        },
        {
          "id": "starter-example-patients",
          "datasetId": "openemr-shared-synthetic-v1",
          "name": "Starter example patients",
          "description": "Imports the bundled OpenEMR example provider users and 14 patient demographics as the first visible seed.",
          "commandName": "seedExampleData",
          "resultPath": "../legacy-openemr/artifacts/latest-seed-result.json"
        }
      ],
      "tests": [
        {
          "id": "smoke",
          "name": "Baseline smoke test",
          "description": "Checks health endpoint, login page, and local admin login.",
          "layer": "smoke",
          "commandName": "smokeTest",
          "resultPath": "../legacy-openemr/artifacts/latest-smoke-test.json"
        },
        {
          "id": "parity-database",
          "name": "Gold database contract",
          "description": "Runs normalized database probes against the seeded legacy MariaDB baseline.",
          "layer": "database",
          "commandName": "parityDatabaseTests",
          "resultPath": "../parity-tests/artifacts/latest-legacy-openemr-database.json"
        },
        {
          "id": "parity-http",
          "name": "HTTP functional contract",
          "description": "Runs health, login form, and application shell checks against the legacy baseline.",
          "layer": "http",
          "commandName": "parityHttpTests",
          "resultPath": "../parity-tests/artifacts/latest-legacy-openemr-http.json"
        },
        {
          "id": "parity-ui",
          "name": "Playwright UI contract",
          "description": "Runs browser login and gold-patient chart navigation checks against the legacy UI.",
          "layer": "ui",
          "commandName": "parityUiTests",
          "resultPath": "../parity-tests/artifacts/latest-legacy-openemr-ui.json"
        },
        {
          "id": "parity-all",
          "name": "Full legacy parity suite",
          "description": "Runs database, HTTP, and Playwright UI suites against the seeded legacy baseline.",
          "layer": "all",
          "commandName": "parityAllTests",
          "resultPath": "../parity-tests/artifacts/latest-legacy-openemr-all.json"
        }
      ]
    }
  ]
}
